// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PROGRESS_STATUS {
  PENDING
  INPROGRESS
  REVIEW
  DONE
}

enum SCOPE {
  SYS
  CO
  PRJ
}

model User {
  id                              BigInt    @id @default(autoincrement())
  email                           String    @unique
  googleId                        String?   @unique @map("google_id")
  password                        String?
  displayName                     String    @map("display_name")
  avatarUrl                       String?   @map("avatar_url")
  emailVerifiedAt                 DateTime? @map("email_verified_at")
  emailVerificationTokenHash      String?   @unique @map("email_verification_token_hash")
  emailVerificationTokenExpiresAt DateTime? @map("email_verification_token_expires_at")
  isDeleted                       Boolean   @default(false) @map("is_deleted")
  createdBy                       BigInt?   @map("created_by")
  updatedBy                       BigInt?   @map("updated_by")
  deletedBy                       BigInt?   @map("deleted_by")
  createdAt                       DateTime  @default(now()) @map("created_at")
  updatedAt                       DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt                       DateTime? @map("deleted_at")

  // Relations with itself for createdBy, updatedBy, deletedBy
  createdByUser User?  @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User?  @relation("updatedByUser", fields: [updatedBy], references: [id])
  deletedByUser User?  @relation("deletedByUser", fields: [deletedBy], references: [id])
  createdUsers  User[] @relation("createdByUser")
  updatedUsers  User[] @relation("updatedByUser")
  deletedUsers  User[] @relation("deletedByUser")

  // Relations with role model
  createdRoles Role[] @relation("createdByUser")
  updatedRoles Role[] @relation("updatedByUser")

  // Relations with userRole model
  userRoles UserRole[]

  // Relations with company model
  createdCompanies Company[] @relation("createdByUser")
  updatedCompanies Company[] @relation("updatedByUser")

  // Relations with project model
  createdProjects Project[] @relation("createdByUser")
  updatedProjects Project[] @relation("updatedByUser")

  // Relations with folder model
  createdFolders Folder[] @relation("createdByUser")
  updatedFolders Folder[] @relation("updatedByUser")

  // Relations with file model
  createdFiles File[] @relation("createdByUser")
  updatedFiles File[] @relation("updatedByUser")

  // Relations with task model
  createdTasks  Task[] @relation("createdByUser")
  updatedTasks  Task[] @relation("updatedByUser")
  assignedTasks Task[] @relation("assignedByUser")

  // Relations with taskCommentFrame model
  createdTaskCommentFrames TaskCommentFrame[] @relation("createdByUser")
  updatedTaskCommentFrames TaskCommentFrame[] @relation("updatedByUser")

  // Relations with taskComment model
  createdTaskComments TaskComment[] @relation("createdByUser")
  updatedTaskComments TaskComment[] @relation("updatedByUser")

  // Relations with refreshToken model
  refreshTokens RefreshToken[]

  // Configs
  @@map("users")
}

model Role {
  id        BigInt   @id @default(autoincrement())
  name      String
  scope     SCOPE    @default(SYS)
  companyId BigInt?  @map("company_id")
  projectId BigInt?  @map("project_id")
  createdBy BigInt?  @map("created_by")
  updatedBy BigInt?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations with user model
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User? @relation("updatedByUser", fields: [updatedBy], references: [id])

  // Relations with rolePermission model
  rolePermissions RolePermission[]

  // Relations with userRole model
  userRoles UserRole[]

  // Relations with company model
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relations with project model
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Configs
  @@map("roles")
}

model Permission {
  id    BigInt @id @default(autoincrement())
  name  String @unique
  scope SCOPE  @default(SYS)

  // Relations with rolePermission model
  rolePermissions RolePermission[]

  // Configs
  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  // Relations with role and permission models
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  // Configs
  @@map("role_permissions")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  // Relations with user and role models
  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  // Configs
  @@map("user_roles")
}

model Company {
  id        BigInt   @id @default(autoincrement())
  name      String
  createdBy BigInt?  @map("created_by")
  updatedBy BigInt?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations with user model
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User? @relation("updatedByUser", fields: [updatedBy], references: [id])

  // Relations with project model
  projects Project[]

  // Relations with role model
  roles Role[]

  // Configs
  @@map("companies")
}

model Project {
  id        BigInt   @id @default(autoincrement())
  name      String
  companyId BigInt   @map("company_id")
  createdBy BigInt?  @map("created_by")
  updatedBy BigInt?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations with company model
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relations with user model
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User? @relation("updatedByUser", fields: [updatedBy], references: [id])

  // Relations with role model
  roles Role[]

  // Relations with folder model
  folders Folder[]

  @@index([companyId])
  // Configs
  @@map("projects")
}

model Folder {
  id          BigInt   @id @default(autoincrement())
  name        String
  description String?
  index       Int      @default(autoincrement())
  parentId    BigInt?  @map("parent_id")
  projectId   BigInt   @map("project_id")
  createdBy   BigInt?  @map("created_by")
  updatedBy   BigInt?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations with project model
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Relations with user model
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User? @relation("updatedByUser", fields: [updatedBy], references: [id])

  // Relations with itself for parent-child relationship
  parent   Folder?  @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderToFolder")

  // Relations with file model
  files File[]

  @@index([projectId])
  @@index([parentId])
  // Configs
  @@map("folders")
}

model File {
  id        BigInt   @id @default(autoincrement())
  name      String
  index     Int      @default(autoincrement())
  folderId  BigInt   @map("folder_id")
  createdBy BigInt?  @map("created_by")
  updatedBy BigInt?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations with folder model
  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // Relations with user model
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User? @relation("updatedByUser", fields: [updatedBy], references: [id])

  // Relations with task model
  tasks Task[]

  @@index([folderId])
  // Configs
  @@map("files")
}

model Task {
  id          BigInt          @id @default(autoincrement())
  title       String
  description String?
  status      PROGRESS_STATUS @default(PENDING)
  index       Int             @default(autoincrement())
  parentId    BigInt?         @map("parent_id")
  fileId      BigInt          @map("file_id")
  assignedBy  BigInt?         @map("assigned_by")
  createdBy   BigInt?         @map("created_by")
  updatedBy   BigInt?         @map("updated_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")

  // Relations with itself for parent-child relationship
  parent   Task?  @relation("TaskToTask", fields: [parentId], references: [id], onDelete: Cascade)
  children Task[] @relation("TaskToTask")

  // Relations with file model
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  // Relations with user model
  createdByUser  User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser  User? @relation("updatedByUser", fields: [updatedBy], references: [id])
  assignedByUser User? @relation("assignedByUser", fields: [assignedBy], references: [id])

  // Relations with taskCommentFrame model
  commentFrames TaskCommentFrame[]

  @@index([fileId])
  @@index([parentId])
  // Configs
  @@map("tasks")
}

model TaskCommentFrame {
  id        BigInt   @id @default(autoincrement())
  startX    Decimal  @map("start_x") @db.Decimal(10, 4)
  startY    Decimal  @map("start_y") @db.Decimal(10, 4)
  endX      Decimal  @map("end_x") @db.Decimal(10, 4)
  endY      Decimal  @map("end_y") @db.Decimal(10, 4)
  taskId    BigInt   @map("task_id")
  createdBy BigInt?  @map("created_by")
  updatedBy BigInt?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations with task model
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Relations with user model
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User? @relation("updatedByUser", fields: [updatedBy], references: [id])

  // Relations with taskComment model
  comments TaskComment[]

  @@index([taskId])
  // Configs
  @@map("task_comment_frames")
}

model TaskComment {
  id        BigInt   @id @default(autoincrement())
  content   String
  frameId   BigInt   @map("frame_id")
  createdBy BigInt?  @map("created_by")
  updatedBy BigInt?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations with frame model
  frame TaskCommentFrame @relation(fields: [frameId], references: [id], onDelete: Cascade)

  // Relations with user model
  createdByUser User? @relation("createdByUser", fields: [createdBy], references: [id])
  updatedByUser User? @relation("updatedByUser", fields: [updatedBy], references: [id])

  @@index([frameId])
  // Configs
  @@map("task_comments")
}

model RefreshToken {
  token     String   @id
  userId    BigInt   @map("user_id")
  expiresAt DateTime @map("expires_at")

  // Relations with user model
  user User @relation(fields: [userId], references: [id])

  // Configs
  @@map("refresh_tokens")
}

// KietDM #001
model BlacklistToken {
  token     String   @id
  expiresAt DateTime @map("expires_at")

  // Configs
  @@map("blacklist_tokens")
}
